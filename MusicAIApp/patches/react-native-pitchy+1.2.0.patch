+namespace {
+constexpr double kNativeNoiseFloorDb = -55.0;
+constexpr double kConfidenceThreshold = 0.80;
+constexpr double kEmaAlpha = 0.30;
+constexpr NSUInteger kPitchWindowSize = 5;
+constexpr NSInteger kNoStableMidi = -1;
+constexpr NSUInteger kHysteresisFrames = 2;
+constexpr double kBoundaryMarginCents = 6.0;
+constexpr double kA4Frequency = 440.0;
+
+static double MedianOf(const std::deque<double> &values) {
+    if (values.empty()) {
+        return 0.0;
+    }
+
+    std::vector<double> sorted(values.begin(), values.end());
+    std::sort(sorted.begin(), sorted.end());
+    const size_t middle = sorted.size() / 2;
+
+    if (sorted.size() % 2 == 1) {
+        return sorted[middle];
+    }
+
+    return (sorted[middle - 1] + sorted[middle]) / 2.0;
+}
+
+static NSInteger MidiFromFrequency(double frequency) {
+    if (frequency <= 0.0) {
+        return kNoStableMidi;
+    }
+
+    return static_cast<NSInteger>(llround(69.0 + (12.0 * log2(frequency / kA4Frequency))));
+}
+
+static double FrequencyFromMidi(NSInteger midi) {
+    return kA4Frequency * pow(2.0, (static_cast<double>(midi) - 69.0) / 12.0);
+}
+
+static double CentsFromBoundary(double frequency, NSInteger midiA, NSInteger midiB) {
+    const double leftFrequency = FrequencyFromMidi(std::min(midiA, midiB));
+    const double rightFrequency = FrequencyFromMidi(std::max(midiA, midiB));
+    const double boundaryFrequency = sqrt(leftFrequency * rightFrequency);
+    return 1200.0 * log2(frequency / boundaryFrequency);
+}
