# Backend API base URL.
# For local device testing, replace YOUR_LOCAL_IP with your computer's LAN IP.
# Example: http://192.168.1.23:8000
EXPO_PUBLIC_API_BASE_URL=http://YOUR_LOCAL_IP:8000

# Supabase project URL used by the Expo app
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key used by the Expo app.
# This key is public by design, but still use placeholders in committed examples.
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-public-key
