# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# App environment. Use production in deployed environments.
APP_ENV=development

# Server-side Supabase key.
# Use the service role key only on the backend.
# Never expose this value in frontend code.
SUPABASE_KEY=your-supabase-service-role-key

# Supabase Storage bucket used for uploaded audio files
SUPABASE_AUDIO_BUCKET=audio-uploads

# Prefix/path inside the audio bucket for analysis uploads
SUPABASE_AUDIO_PREFIX=analysis

# Maximum age for queued/running analysis jobs before they time out
ANALYSIS_JOB_TIMEOUT_SECONDS=900

# Allowed frontend origins for CORS.
# Development examples:
# - http://localhost:8081
# - http://localhost:19006
# - http://YOUR_LOCAL_IP:8081
# For production, replace with the deployed frontend origin.
CORS_ALLOW_ORIGINS=http://localhost:8081,http://localhost:19006

# Logging level
LOG_LEVEL=INFO
